---
const { lang = 'de' } = Astro.props;
const API_URL = import.meta.env.PUBLIC_API_URL;

const t = {
  de: {
    title: "Portfolio Agent",
    online: "Online",
    welcome: "Hallo! Ich bin Sinans KI-Assistent. Frag mich nach Skills, Projekten oder Verfügbarkeit – auf Deutsch oder Englisch.",
    placeholder: "Schreibe eine Nachricht…",
    error: "Verbindungsfehler. Bitte erneut versuchen.",
  },
  en: {
    title: "Portfolio Agent",
    online: "Online",
    welcome: "Hi! I'm Sinan's AI assistant. Ask me about skills, projects, or availability – in English or German.",
    placeholder: "Type a message…",
    error: "Connection error. Please try again.",
  }
};
const text = lang === 'en' ? t.en : t.de;
---

<div
  id={`agent-chat-${lang}`}
  class="bg-slate-800 rounded-2xl border border-slate-700 shadow-xl flex flex-col"
  style="height: 560px;"
  data-api-url={API_URL}
  data-lang={lang}
  data-text={JSON.stringify(text)}
>
  <!-- Header -->
  <div class="flex items-center gap-3 px-5 py-4 border-b border-slate-700/60 shrink-0">
    <div class="p-2 bg-green-500/20 rounded-lg text-green-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="text-white font-bold text-sm">{text.title}</h3>
      <div class="flex items-center gap-1.5 mt-0.5">
        <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
        <span class="text-green-400 text-xs">{text.online}</span>
      </div>
    </div>
  </div>

  <!-- Messages Area -->
  <div
    id={`agent-messages-${lang}`}
    class="flex-1 overflow-y-auto px-4 py-4 space-y-3"
  ></div>

  <!-- Input Area -->
  <div class="px-4 py-4 border-t border-slate-700/60 shrink-0">
    <form id={`agent-form-${lang}`} class="flex gap-2">
      <input
        id={`agent-input-${lang}`}
        type="text"
        autocomplete="off"
        placeholder={text.placeholder}
        aria-label={lang === 'de' ? 'Nachricht an den Agenten' : 'Message to the agent'}
        class="flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-slate-200 text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-green-500/50 transition-colors"
      />
      <button
        id={`agent-btn-${lang}`}
        type="submit"
        aria-label={lang === 'de' ? 'Senden' : 'Send'}
        class="bg-green-600 hover:bg-green-500 disabled:opacity-40 disabled:cursor-not-allowed text-white rounded-xl px-4 py-2.5 transition-colors flex items-center"
      >
        <svg id={`agent-send-icon-${lang}`} xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
        </svg>
        <svg id={`agent-spinner-${lang}`} class="animate-spin h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </button>
    </form>
    <div class="mt-3 text-[10px] text-slate-500 uppercase tracking-widest flex items-center gap-2">
      <span class="text-green-500/50">●</span>
      <strong class="text-slate-400 font-semibold">Tech:</strong> Async Tool-Calling · Multi-Provider Fallback (Groq → Gemini → OpenAI) · LangChain · FastAPI
    </div>
  </div>
</div>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'isomorphic-dompurify';

  document.querySelectorAll<HTMLElement>('[id^="agent-chat-"]').forEach((container) => {
    const API_URL = container.dataset.apiUrl!;
    const lang = container.dataset.lang!;
    const text = JSON.parse(container.dataset.text!);

    const messagesArea = document.getElementById(`agent-messages-${lang}`)!;
    const form = document.getElementById(`agent-form-${lang}`) as HTMLFormElement;
    const input = document.getElementById(`agent-input-${lang}`) as HTMLInputElement;
    const btn = document.getElementById(`agent-btn-${lang}`) as HTMLButtonElement;
    const sendIcon = document.getElementById(`agent-send-icon-${lang}`)!;
    const spinner = document.getElementById(`agent-spinner-${lang}`)!;

    const history: Array<{ role: 'user' | 'assistant'; content: string }> = [];

    function scrollToBottom() {
      messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function appendMessage(role: 'user' | 'assistant', sanitizedHtml: string): HTMLElement {
      const wrapper = document.createElement('div');
      wrapper.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';

      const bubble = document.createElement('div');
      bubble.className =
        role === 'user'
          ? 'max-w-[80%] bg-blue-600/80 text-white rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm leading-relaxed'
          : 'max-w-[80%] bg-slate-700/60 text-slate-200 rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm agent-prose';
      // sanitizedHtml is always the output of DOMPurify.sanitize() before calling this function
      bubble.innerHTML = sanitizedHtml;

      wrapper.appendChild(bubble);
      messagesArea.appendChild(wrapper);
      scrollToBottom();
      return bubble;
    }

    function addTypingIndicator(): HTMLElement {
      const wrapper = document.createElement('div');
      wrapper.id = `typing-${lang}`;
      wrapper.className = 'flex justify-start';

      const bubble = document.createElement('div');
      bubble.className = 'bg-slate-700/60 rounded-2xl rounded-tl-sm px-4 py-3 flex gap-1.5 items-center';

      for (let i = 0; i < 3; i++) {
        const dot = document.createElement('span');
        dot.className = 'w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce';
        dot.style.animationDelay = `${i * 150}ms`;
        bubble.appendChild(dot);
      }

      wrapper.appendChild(bubble);
      messagesArea.appendChild(wrapper);
      scrollToBottom();
      return wrapper;
    }

    // Welcome message
    appendMessage('assistant', DOMPurify.sanitize(text.welcome));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const message = input.value.trim();
      if (!message) return;

      input.value = '';
      appendMessage('user', DOMPurify.sanitize(message));

      btn.disabled = true;
      input.disabled = true;
      sendIcon.classList.add('hidden');
      spinner.classList.remove('hidden');

      const typingEl = addTypingIndicator();

      try {
        const res = await fetch(`${API_URL}/api/agent`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message, language: lang, history }),
        });

        const data = await res.json();
        typingEl.remove();

        let replyContent: string;
        if (Array.isArray(data.reply)) {
          replyContent = data.reply
            .filter((b: { type: string }) => b.type === 'text')
            .map((b: { text: string }) => b.text)
            .join('\n');
        } else {
          replyContent = data.reply || text.error;
        }

        const parsed = DOMPurify.sanitize(await marked.parse(replyContent));
        appendMessage('assistant', parsed);

        history.push({ role: 'user', content: message });
        history.push({ role: 'assistant', content: replyContent });
        // Keep last 10 exchanges (20 messages)
        while (history.length > 20) history.splice(0, 2);

      } catch {
        typingEl.remove();
        const bubble = appendMessage('assistant', DOMPurify.sanitize(text.error));
        bubble.classList.add('text-red-400');
      } finally {
        btn.disabled = false;
        input.disabled = false;
        sendIcon.classList.remove('hidden');
        spinner.classList.add('hidden');
        input.focus();
      }
    });
  });
</script>

<style>
  .agent-prose p { margin-bottom: 0.75rem; }
  .agent-prose p:last-child { margin-bottom: 0; }
  .agent-prose strong { color: white; font-weight: 700; }
  .agent-prose em { color: rgb(167 243 208); font-style: italic; }
  .agent-prose ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.75rem; }
  .agent-prose ol { list-style-type: decimal; padding-left: 1.25rem; margin-bottom: 0.75rem; }
  .agent-prose li { margin-bottom: 0.25rem; }
  .agent-prose code { background: rgb(15 23 42); color: rgb(52 211 153); padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-family: monospace; font-size: 0.8rem; }
  .agent-prose h1, .agent-prose h2, .agent-prose h3 { color: white; font-weight: 700; margin: 1rem 0 0.5rem; }

  #agent-messages-de,
  #agent-messages-en {
    scrollbar-width: thin;
    scrollbar-color: rgb(51 65 85) transparent;
  }
  #agent-messages-de::-webkit-scrollbar,
  #agent-messages-en::-webkit-scrollbar { width: 4px; }
  #agent-messages-de::-webkit-scrollbar-track,
  #agent-messages-en::-webkit-scrollbar-track { background: transparent; }
  #agent-messages-de::-webkit-scrollbar-thumb,
  #agent-messages-en::-webkit-scrollbar-thumb { background: rgb(51 65 85); border-radius: 2px; }
</style>
