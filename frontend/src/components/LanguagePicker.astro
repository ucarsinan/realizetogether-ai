---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLang = Astro.currentLocale || 'de';
const currentPath = Astro.url.pathname;
const targetLang = currentLang === 'de' ? 'en' : 'de';

const segments = currentPath.split('/').filter(Boolean);
if (segments.length > 0 && (segments[0] === 'en' || segments[0] === 'de')) {
  segments.shift(); 
}
const slug = segments.join('/');

// Mapping für die URL-Übersetzung
const routeTranslations: Record<string, string> = {
    // DE -> EN
    'lebenslauf': 'resume', // <--- WICHTIG: zu 'resume'
    'projekte': 'projects',
    'profil': 'about',
    'kontakt': 'contact',
    'impressum': 'imprint',
    'datenschutz': 'privacy',
    
    // EN -> DE
    'resume': 'lebenslauf', // <--- WICHTIG: von 'resume'
    'cv': 'lebenslauf',     // (Fallback, falls alte Links existieren)
    'projects': 'projekte',
    'about': 'profil',
    'contact': 'kontakt',
    'imprint': 'impressum',
    'privacy': 'datenschutz'
};

const translatedSlug = routeTranslations[slug] || slug;
const targetUrl = getRelativeLocaleUrl(targetLang, translatedSlug);
---

<a
  href={targetUrl}
  class="flex items-center justify-center w-10 h-8 rounded-md border border-slate-700 bg-slate-900/50 text-xs font-bold text-slate-300 hover:text-white hover:border-emerald-500 hover:bg-slate-800 transition-all uppercase tracking-wider"
  aria-label={targetLang === 'en' ? 'Switch to English' : 'Zu Deutsch wechseln'}
>
  {targetLang === 'en' ? 'EN' : 'DE'}
</a>