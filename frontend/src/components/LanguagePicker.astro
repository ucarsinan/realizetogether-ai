---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLang = Astro.currentLocale || 'de';
const currentPath = Astro.url.pathname;
const targetLang = currentLang === 'de' ? 'en' : 'de';

// 1. Pfad in Teile zerlegen
const segments = currentPath.split('/').filter(Boolean);

// Wenn das erste Segment die Sprache ist ('en'), entfernen wir es, um den "Kern-Slug" zu bekommen
if (segments.length > 0 && (segments[0] === 'en' || segments[0] === 'de')) {
  segments.shift(); 
}

const slug = segments.join('/');

// 2. Mapping-Tabelle für die Übersetzung der URLs
// Key = Aktueller Slug, Value = Ziel-Slug in der anderen Sprache
const routeTranslations: Record<string, string> = {
    // DE -> EN
    'lebenslauf': 'cv',
    'projekte': 'projects',
    'profil': 'about',
    'kontakt': 'contact',
    'impressum': 'imprint',
    'datenschutz': 'privacy',
    
    // EN -> DE
    'cv': 'lebenslauf',
    'projects': 'projekte',
    'about': 'profil',
    'contact': 'kontakt',
    'imprint': 'impressum',
    'privacy': 'datenschutz'
};

// 3. Ziel-Slug ermitteln (wenn er in der Liste ist, übersetzen, sonst behalten)
// z.B. "lebenslauf" wird zu "cv", aber "ai" bleibt "ai"
const translatedSlug = routeTranslations[slug] || slug;

const targetUrl = getRelativeLocaleUrl(targetLang, translatedSlug);
---

<a
  href={targetUrl}
  class="flex items-center justify-center w-10 h-8 rounded-md border border-slate-700 bg-slate-900/50 text-xs font-bold text-slate-300 hover:text-white hover:border-emerald-500 hover:bg-slate-800 transition-all uppercase tracking-wider"
  aria-label={targetLang === 'en' ? 'Switch to English' : 'Zu Deutsch wechseln'}
>
  {targetLang === 'en' ? 'EN' : 'DE'}
</a>