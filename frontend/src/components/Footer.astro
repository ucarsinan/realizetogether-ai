---
import { getRelativeLocaleUrl } from 'astro:i18n';
const currentYear = new Date().getFullYear();
const lang = Astro.currentLocale || 'de';

// Mapping (wie in Navbar)
const routes = {
  home: { de: '/', en: '/' },
  about: { de: 'profil', en: 'about' },
  projects: { de: 'projekte', en: 'projects' },
  cv: { de: 'lebenslauf', en: 'cv' },
  contact: { de: 'kontakt', en: 'contact' },
  privacy: { de: 'datenschutz', en: 'privacy' },
  imprint: { de: 'impressum', en: 'imprint' }
};

const t = {
  description: lang === 'de'
      ? 'Diplom-Informatiker & Senior Full Stack Developer. Ich baue Brücken zwischen komplexen Enterprise-Systemen und moderner KI-Technologie.'
      : 'Computer Scientist (Diplom) & Senior Full Stack Developer. I build bridges between complex enterprise systems and modern AI technology.',
  open: 'Open for Projects',
  portfolio: 'Portfolio',
  legal: lang === 'de' ? 'Rechtliches' : 'Legal',
  links: {
    home: 'Home',
    about: lang === 'de' ? 'Profil' : 'About Me',
    projects: lang === 'de' ? 'Projekte' : 'Projects',
    cv: lang === 'de' ? 'Lebenslauf' : 'Resume',
    contact: lang === 'de' ? 'Kontakt' : 'Contact',
    privacy: lang === 'de' ? 'Datenschutz' : 'Privacy Policy',
    imprint: lang === 'de' ? 'Impressum' : 'Imprint'
  }
};

const links = [
  { name: t.links.home, href: getRelativeLocaleUrl(lang, routes.home[lang]) },
  { name: t.links.about, href: getRelativeLocaleUrl(lang, routes.about[lang]) },
  { name: t.links.projects, href: getRelativeLocaleUrl(lang, routes.projects[lang]) },
  { name: t.links.cv, href: getRelativeLocaleUrl(lang, routes.cv[lang]) }
];

const legal = [
  { name: t.links.contact, href: getRelativeLocaleUrl(lang, routes.contact[lang]) },
  { name: t.links.privacy, href: getRelativeLocaleUrl(lang, routes.privacy[lang]) },
  { name: t.links.imprint, href: getRelativeLocaleUrl(lang, routes.imprint[lang]) }
];
---
<footer class="bg-slate-950 border-t border-slate-900 pt-16 pb-8 text-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-2 space-y-4">
        <a
          href={getRelativeLocaleUrl(lang, '/')}
          class="text-2xl font-bold text-white tracking-tight flex items-center gap-2"
        >
          Sinan<span class="text-emerald-400">.AI</span>
        </a>
        <p class="text-slate-500 leading-relaxed max-w-sm">
          {t.description}
        </p>

        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-medium"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          {t.open}
        </div>
      </div>

      <div>
        <h3 class="font-bold text-white mb-4">{t.portfolio}</h3>
        <ul class="space-y-3">
          {
            links.map((link) => (
              <li>
                <a href={link.href} class="text-slate-500 hover:text-blue-400 transition-colors">
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-white mb-4">{t.legal}</h3>
        <ul class="space-y-3">
          {
            legal.map((link) => (
              <li>
                <a href={link.href} class="text-slate-500 hover:text-emerald-400 transition-colors">
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="flex gap-4 mt-6">
             <a href="https://github.com/" target="_blank" class="text-slate-600 hover:text-white transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg></a>
             <a href="https://linkedin.com/" target="_blank" class="text-slate-600 hover:text-white transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"></path></svg></a>
        </div>
      </div>
    </div>
    <div class="border-t border-slate-900 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-600">
      <p>&copy; {currentYear} Sinan Uçar. All rights reserved.</p>
      <p class="flex items-center gap-1">Built with <span class="text-slate-400 font-medium">Astro</span>, <span class="text-slate-400 font-medium">Tailwind</span> & <span class="text-slate-400 font-medium">Google Gemini</span></p>
    </div>
  </div>
</footer>