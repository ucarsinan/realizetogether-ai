---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    title: 'AI Knowledge Engine (RAG)',
    description:
      'Development of a RAG architecture (Retrieval Augmented Generation) for context-based information processing. Backend with Python/FastAPI, vector logic via LangChain, and multimodal analysis (Vision) integrated into an Astro frontend.',
    tags: ['AI Engineering', 'RAG Architecture', 'Computer Vision', 'FastAPI', 'Python'],
    status: 'Live',
    link: '/ai',
    linkText: 'View Live Demo'
  },
  {
    title: 'Enterprise Component Library',
    description:
      'Establishment and continuous maintenance of a Storybook component library as a standardization matrix for organization-wide UI development at Ceyoniq.',
    tags: ['Solutions Architecture', 'Web Components', 'Lit', 'Vue.js', 'TypeScript'],
    status: 'Live',
    linkText: 'Internal Project (Ceyoniq)'
  },
  {
    title: 'Instacount® Core Development',
    description:
      'Porting and continuous development of a core product in C#/.NET, including performance tuning and reporting with SQL and Crystal Reports at Invitec.',
    tags: ['Backend Engineering', 'C#', '.NET', 'SQL', 'Performance Tuning'],
    status: 'Live',
    linkText: 'Legacy Project'
  },
  {
    title: 'Rich Ads & Landing Pages',
    description:
      'Planning and implementation of responsive landing pages, microsites, and interactive rich ads for SMEs and international agency clients. Focus on performance and cross-browser compatibility.',
    tags: ['Frontend', 'HTML5', 'CSS3', 'JavaScript', 'Ad Tech'],
    status: 'Live'
  }
];
---

<Layout title="Sinan.AI - Projects">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="text-center mb-16 space-y-4 animate-fade-in">
      <h1
        class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-emerald-400 text-transparent bg-clip-text pb-2"
      >
        Technical References
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        From complex enterprise backends to modern AI pipelines.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((p) => (
          // @ts-ignore
          <ProjectCard
            title={p.title}
            description={p.description}
            tags={p.tags}
            @ts-ignore
            status={p.status}
            link={p.link}
            linkText={p.linkText}
          />
        ))
      }
    </div>
  </div>
</Layout>
