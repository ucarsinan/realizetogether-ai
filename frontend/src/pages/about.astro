---
import Layout from '../layouts/Layout.astro';

// Daten exakt aus dem Abschnitt "TECHNOLOGISCHE KOMPETENZEN" (Seite 2)
const skills = [
  "TypeScript", "JavaScript (ES6+)", "Vue.js", "React", 
  "Web Components / Lit", "HTML5 / CSS3 / Tailwind", 
  "Node.js / Express", "MongoDB / SQL", "C# / Java",
  "Docker / Git / GitLab", "Playwright / Jest / Vitest"
];

const softSkills = [
  "Teamorientiertes Arbeiten",
  "Hohes Verantwortungsbewusstsein",
  "Analytisches Denken",
  "Flexibilität & Lernbereitschaft",
  "Kommunikationsstark"
];
---

<Layout title="Sinan.AI - Über Mich">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    
    <h1 class="text-4xl md:text-5xl font-bold mb-12 text-center animate-fade-in">
      <span class="bg-gradient-to-r from-blue-400 to-emerald-400 text-transparent bg-clip-text">
        Profil & Kompetenzen
      </span>
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(180px,auto)] animate-fade-in-up">
      
      <div class="md:col-span-2 row-span-2 bg-slate-900/50 border border-slate-800 p-8 rounded-3xl flex flex-col justify-center hover:border-slate-700 transition-colors">
        <h2 class="text-2xl font-bold text-white mb-4">Über Mich</h2>
        <p class="text-slate-400 text-lg leading-relaxed space-y-4">
            Ich bin <strong class="text-emerald-400">Diplom-Informatiker</strong> und erfahrener Full-Stack-Entwickler mit mehr als 15 Jahren Praxis in der Entwicklung performanter, skalierbarer Web- und Backendlösungen.
            <br/><br/>
            Meine Stärken liegen in modernen Web-Technologien (TypeScript, Vue, Web Components) sowie in CI/CD und automatisiertem Testing. 
            Ich bin teamorientiert, lösungsstark und habe ein wachsendes Interesse an KI- und datengetriebenen Anwendungen.
        </p>
      </div>

      <div class="bg-slate-900/50 border border-slate-800 p-6 rounded-3xl hover:border-blue-500/30 transition-colors">
        <h3 class="text-xl font-bold text-blue-400 mb-4">Tech Stack</h3>
        <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
                <span class="text-xs bg-slate-950 border border-slate-800 px-2 py-1 rounded text-slate-300">
                    {skill}
                </span>
            ))}
        </div>
      </div>

      <div class="bg-gradient-to-br from-blue-900/20 to-slate-900 border border-slate-800 p-6 rounded-3xl hover:border-emerald-500/30 transition-colors">
        <h3 class="text-xl font-bold text-emerald-400 mb-4">Soft Skills</h3>
        <ul class="space-y-2 text-slate-400 text-sm">
            {softSkills.map(s => (
                <li class="flex items-center gap-2">✅ {s}</li>
            ))}
        </ul>
      </div>

      <div class="md:col-span-3 bg-slate-900/50 border border-slate-800 p-8 rounded-3xl flex flex-col md:flex-row items-center justify-between gap-8 hover:border-purple-500/30 transition-colors">
        <div class="max-w-2xl">
            <h3 class="text-2xl font-bold text-white mb-2">Sprachen</h3>
            <div class="flex gap-4 text-slate-400">
                <span>🇩🇪 Deutsch (Zweitsprache)</span>
                <span>🇬🇧 Englisch (B1)</span>
                <span>🇹🇷 Türkisch (Muttersprache)</span>
            </div>
        </div>
      </div>

    </div>
  </div>
</Layout>