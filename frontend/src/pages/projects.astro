---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Projekte basierend auf den Tätigkeitsbeschreibungen im CV
const projects = [
  {
    title: "Sinan.AI - Interactive Resume",
    description: "Diese Anwendung. Ein RAG-basiertes Portfolio, das meinen Lebenslauf mittels AI interaktiv macht. Tech-Stack: Python, FastAPI, Astro und Google Gemini.",
    tags: ["Astro", "FastAPI", "Python", "LangChain", "AI"],
    status: "Live",
    link: "#", 
    linkText: "Aktuelle Seite"
  },
  {
    title: "Enterprise Component Library",
    description: "Aufbau und kontinuierliche Pflege einer Storybook-Komponentenbibliothek als Standardisierungsmatrix für die organisationsweite UI-Entwicklung bei Ceyoniq.",
    tags: ["Storybook", "Web Components", "Lit", "Vue.js", "TypeScript"],
    status: "Live",
    linkText: "Internes Projekt"
  },
  {
    title: "Instacount® Weiterentwicklung",
    description: "Portierung und kontinuierliche Weiterentwicklung eines Kernprodukts in C#/.NET einschließlich Performance-Tuning und Reporting mit SQL und Crystal Reports bei Invitec.",
    tags: ["C#", ".NET", "SQL", "Crystal Reports", "Performance Tuning"],
    status: "Live",
    linkText: "Legacy Projekt"
  },
  {
    title: "Rich Ads & Landingpages",
    description: "Planung und Realisierung responsiver Landingpages, Microsites und interaktiver Rich Ads für KMU und internationale Agenturkunden. Fokus auf Performance und Cross-Browser-Kompatibilität.",
    tags: ["HTML5", "CSS3", "JavaScript", "Responsive Design", "Ad Tech"],
    status: "Live"
  }
];
---

<Layout title="Sinan.AI - Projekte">
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    
    <div class="text-center mb-16 space-y-4 animate-fade-in">
      <h1 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-emerald-400 text-transparent bg-clip-text pb-2">
        Ausgewählte Projekte
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Einblicke in meine Arbeit aus über 15 Jahren Entwicklungserfahrung.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p) => (
        // @ts-ignore
        <ProjectCard 
          title={p.title}
          description={p.description}
          tags={p.tags}
          // @ts-ignore
          status={p.status}
          link={p.link}
          linkText={p.linkText}
        />
      ))}
    </div>

  </div>
</Layout>