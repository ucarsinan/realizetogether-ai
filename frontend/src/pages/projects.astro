---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Projekte basierend auf CV und aktuellem Showcase
const projects = [
  {
    title: 'AI Knowledge Engine (RAG)',
    description:
      'Entwicklung einer RAG-Architektur (Retrieval Augmented Generation) zur kontextbasierten Informationsverarbeitung. Backend mit Python/FastAPI, Vektor-Logik via LangChain und multimodale Analyse (Vision) integriert in ein Astro-Frontend.',
    tags: ['AI Engineering', 'RAG Architecture', 'Computer Vision', 'FastAPI', 'Python'],
    status: 'Live',
    link: '/',
    linkText: 'Live Demo ansehen'
  },
  {
    title: 'Enterprise Component Library',
    description:
      'Aufbau und kontinuierliche Pflege einer Storybook-Komponentenbibliothek als Standardisierungsmatrix für die organisationsweite UI-Entwicklung bei Ceyoniq.',
    tags: ['Solutions Architecture', 'Web Components', 'Lit', 'Vue.js', 'TypeScript'],
    status: 'Live',
    linkText: 'Internes Projekt (Ceyoniq)'
  },
  {
    title: 'Instacount® Core Development',
    description:
      'Portierung und kontinuierliche Weiterentwicklung eines Kernprodukts in C#/.NET einschließlich Performance-Tuning und Reporting mit SQL und Crystal Reports bei Invitec.',
    tags: ['Backend Engineering', 'C#', '.NET', 'SQL', 'Performance Tuning'],
    status: 'Live',
    linkText: 'Legacy Projekt'
  },
  {
    title: 'Rich Ads & Landingpages',
    description:
      'Planung und Realisierung responsiver Landingpages, Microsites und interaktiver Rich Ads für KMU und internationale Agenturkunden. Fokus auf Performance und Cross-Browser-Kompatibilität.',
    tags: ['Frontend', 'HTML5', 'CSS3', 'JavaScript', 'Ad Tech'],
    status: 'Live'
  }
];
---

<Layout title="Sinan.AI - Projekte">
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="text-center mb-16 space-y-4 animate-fade-in">
      <h1
        class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-emerald-400 text-transparent bg-clip-text pb-2"
      >
        Technische Referenzen
      </h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Vom komplexen Enterprise-Backend bis zur modernen AI-Pipeline.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((p) => (
          // @ts-ignore
          <ProjectCard
            title={p.title}
            description={p.description}
            tags={p.tags}
            @ts-ignore
            status={p.status}
            link={p.link}
            linkText={p.linkText}
          />
        ))
      }
    </div>
  </div>
</Layout>
