---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <main class="h-screen w-full bg-slate-900 text-white flex flex-col font-mono overflow-hidden relative">
    
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-800/20 via-slate-900 to-slate-900 pointer-events-none"></div>

    <div class="z-10 flex flex-col h-full max-w-3xl mx-auto w-full p-4 md:p-6">
      
      <div class="flex-none text-center space-y-4 pt-4 md:pt-10 pb-6">
        
        <div id="status-badge" class="inline-block bg-emerald-600/10 text-emerald-400 border border-emerald-500/20 px-3 py-1 rounded-full text-[10px] font-bold tracking-[0.2em] uppercase transition-all shadow-[0_0_10px_rgba(16,185,129,0.2)]">
            SYSTEM ONLINE
        </div>

        <h1 class="text-5xl md:text-7xl font-bold bg-gradient-to-r from-cyan-400 via-blue-500 to-emerald-400 text-transparent bg-clip-text drop-shadow-2xl tracking-tight">
            Sinan.AI
        </h1>
        
        <div class="space-y-1">
            <p class="text-lg md:text-xl text-slate-200 font-light tracking-wide">
                Diplom-Informatiker. Solutions Architect.
            </p>
            <p class="text-sm md:text-base text-slate-500 italic">
                Building the bridge between Enterprise & AI.
            </p>
        </div>

        <p class="text-xs text-cyan-500/80 font-semibold tracking-widest uppercase pt-2 animate-pulse">
            Ask me anything about Sinan's experience
        </p>
      </div>

      <div id="chat-container" class="flex-grow w-full bg-slate-800/40 border border-slate-700/50 backdrop-blur-sm rounded-xl p-4 md:p-6 overflow-y-auto flex flex-col gap-4 shadow-inner scroll-smooth mb-4">
        
        <div class="self-start max-w-[85%] md:max-w-[75%] bg-slate-800 border border-slate-700 text-slate-200 px-5 py-3 rounded-2xl rounded-tl-none text-sm leading-relaxed shadow-lg">
            <div class="flex items-center gap-2 mb-2 border-b border-slate-700/50 pb-1">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <span class="font-bold text-[10px] text-emerald-400 tracking-wider opacity-80">AI CORE</span>
            </div>
            Hallo! Ich habe Zugriff auf Sinans vollständigen Werdegang. Frag mich zu seinen Projekten, seinem Tech-Stack oder seiner Erfahrung.
        </div>

      </div>

      <div class="flex-none pb-2">
        <div class="relative group">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-500 to-emerald-500 rounded-lg opacity-30 group-focus-within:opacity-100 transition duration-500 blur"></div>
            
            <div class="relative flex gap-0 bg-slate-900 rounded-lg">
                <input 
                    type="text" 
                    id="user-input" 
                    placeholder="E.g.: 'Was ist sein Tech Stack?'" 
                    class="w-full bg-slate-800 border border-slate-700 text-white px-6 py-4 rounded-l-lg focus:outline-none focus:bg-slate-800/80 transition-all placeholder-slate-500 text-sm md:text-base"
                />
                <button 
                    id="send-btn" 
                    class="px-6 md:px-8 bg-blue-600 hover:bg-blue-500 text-white rounded-r-lg font-bold transition-all hover:shadow-[0_0_15px_rgba(37,99,235,0.5)] border-t border-b border-r border-blue-500/50"
                >
                    ➜
                </button>
            </div>
        </div>
        
        <div class="text-center mt-3">
            <p class="text-[10px] text-slate-600 tracking-widest uppercase">
                Powered by Gemini Flash & FastAPI
            </p>
        </div>
      </div>

    </div>

  </main>
</Layout>

<script>
  const input = document.getElementById('user-input');
  const btn = document.getElementById('send-btn');
  const chatContainer = document.getElementById('chat-container');
  const badge = document.getElementById('status-badge');

  // Deine API URL
  const API_URL = "https://8000-firebase-realizetogether-ai-1768386888249.cluster-6vyo4gb53jczovun3dxslzjahs.cloudworkstations.dev/api/chat";

  function appendMessage(text, sender) {
    if (!chatContainer) return;

    const div = document.createElement('div');
    const isUser = sender === 'user';

    // Design der Chatblasen (angepasst an den Style)
    div.className = isUser 
        ? `self-end max-w-[85%] md:max-w-[75%] bg-blue-600/10 border border-blue-500/30 text-blue-100 px-5 py-3 rounded-2xl rounded-tr-none text-sm shadow-md`
        : `self-start max-w-[85%] md:max-w-[75%] bg-slate-800 border border-slate-700 text-slate-200 px-5 py-3 rounded-2xl rounded-tl-none text-sm shadow-md`;

    // Kleines Label über dem Text
    const labelHeader = isUser 
        ? `<div class="flex items-center justify-end gap-2 mb-1 border-b border-blue-500/20 pb-1"><span class="font-bold text-[10px] text-blue-400 tracking-wider opacity-80">YOU</span><span class="w-2 h-2 rounded-full bg-blue-500"></span></div>`
        : `<div class="flex items-center gap-2 mb-1 border-b border-slate-700/50 pb-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span><span class="font-bold text-[10px] text-emerald-400 tracking-wider opacity-80">AI CORE</span></div>`;
    
    div.innerHTML = `
        ${labelHeader}
        <span class="leading-relaxed whitespace-pre-line block">${text}</span>
    `;

    chatContainer.appendChild(div);
    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
  }

  function showTypingIndicator() {
    if (!chatContainer) return null;
    const div = document.createElement('div');
    div.id = "typing-indicator";
    div.className = `self-start bg-slate-800 border border-slate-700 px-5 py-4 rounded-2xl rounded-tl-none text-sm shadow-md flex gap-1.5 items-center`;
    div.innerHTML = `
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce"></span>
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce delay-75"></span>
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-bounce delay-150"></span>
    `;
    chatContainer.appendChild(div);
    chatContainer.scrollTo({ top: chatContainer.scrollHeight, behavior: 'smooth' });
    return div;
  }

  async function sendMessage() {
    // @ts-ignore
    if (!input || !input.value.trim()) return;

    // @ts-ignore
    const userMessage = input.value;
    // @ts-ignore
    input.value = ""; 

    appendMessage(userMessage, 'user');

    if (badge) {
        badge.innerText = "PROCESSING...";
        badge.classList.add("text-yellow-400", "border-yellow-500/50");
        badge.classList.remove("text-emerald-400", "border-emerald-500/20");
    }
    const loader = showTypingIndicator();

    try {
      const response = await fetch(API_URL, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: userMessage })
      });

      const data = await response.json();

      if (loader) loader.remove();
      appendMessage(data.reply, 'ai');
      
      if (badge) {
          badge.innerText = "SYSTEM ONLINE";
          badge.classList.remove("text-yellow-400", "border-yellow-500/50");
          badge.classList.add("text-emerald-400", "border-emerald-500/20");
      }

    } catch (error) {
      if (loader) loader.remove();
      appendMessage("Error: Connection lost. Is the backend running?", 'ai');
      if (badge) badge.innerText = "ERROR";
    }
  }

  if (btn) btn.addEventListener('click', sendMessage);
  if (input) input.addEventListener('keypress', (e) => {
      // @ts-ignore
      if (e.key === 'Enter') sendMessage();
  });
</script>